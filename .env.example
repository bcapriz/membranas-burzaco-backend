# Conexión a MongoDB Atlas (o local)
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/membranas-burzaco

# Secreto para firmar JWT (generar uno largo y aleatorio)
JWT_SECRET=cambiar_por_un_secreto_largo_y_aleatorio

# Puerto del servidor
PORT=4000

# Orígenes permitidos para CORS (URL del frontend en producción).
# Varios separados por coma. localhost:5173 ya está permitido siempre para desarrollo.
CLIENT_URL=https://www.tudominio.com.ar,https://tudominio.com.ar

# Credenciales del admin inicial (usadas por npm run seed)
ADMIN_EMAIL=admin@burzaco.com.ar
ADMIN_PASSWORD=cambiar123

# (Opcional) Cloudinary para subir imágenes persistentes
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
